{
  "$schema": "https://schemas.designtokens.org/2025-10/format.json",
  "$description": "Example DTCG source — a small dimensional system with OKLCH primary + warning sentiment, three emphasis levels, four states. Demonstrates the projection fn-design-md emit-design-md.mjs performs.",
  "color": {
    "primary": {
      "$value": "oklch(55% 0.18 250)",
      "$type": "color",
      "$description": "Neutral high-emphasis brand colour"
    },
    "primary-hover": {
      "$value": "oklch(48% 0.18 250)",
      "$type": "color"
    },
    "primary-active": {
      "$value": "oklch(42% 0.18 250)",
      "$type": "color"
    },
    "primary-disabled": {
      "$value": "oklch(75% 0.06 250)",
      "$type": "color"
    },
    "on-primary": {
      "$value": "#FFFFFF",
      "$type": "color"
    },
    "warning": {
      "$value": "oklch(68% 0.17 60)",
      "$type": "color"
    },
    "warning-hover": {
      "$value": "oklch(60% 0.17 60)",
      "$type": "color"
    },
    "on-warning": {
      "$value": "oklch(20% 0.04 60)",
      "$type": "color"
    },
    "surface": {
      "$value": "#FFFFFF",
      "$type": "color"
    },
    "surface-elevated": {
      "$value": "oklch(98% 0.005 250)",
      "$type": "color"
    },
    "fg": {
      "$value": "oklch(20% 0.01 250)",
      "$type": "color"
    },
    "fg-muted": {
      "$value": "oklch(45% 0.01 250)",
      "$type": "color"
    },
    "border": {
      "$value": "oklch(88% 0.005 250)",
      "$type": "color"
    }
  },
  "typography": {
    "heading-lg": {
      "$value": {
        "fontFamily": [
          "Inter",
          "sans-serif"
        ],
        "fontSize": "32px",
        "fontWeight": 600,
        "lineHeight": 1.2,
        "letterSpacing": "-0.01em"
      },
      "$type": "typography"
    },
    "heading-md": {
      "$value": {
        "fontFamily": [
          "Inter",
          "sans-serif"
        ],
        "fontSize": "24px",
        "fontWeight": 600,
        "lineHeight": 1.3
      },
      "$type": "typography"
    },
    "body-md": {
      "$value": {
        "fontFamily": [
          "Inter",
          "sans-serif"
        ],
        "fontSize": "16px",
        "fontWeight": 400,
        "lineHeight": 1.5
      },
      "$type": "typography"
    },
    "body-sm": {
      "$value": {
        "fontFamily": [
          "Inter",
          "sans-serif"
        ],
        "fontSize": "14px",
        "fontWeight": 400,
        "lineHeight": 1.5
      },
      "$type": "typography"
    },
    "label-md": {
      "$value": {
        "fontFamily": [
          "Inter",
          "sans-serif"
        ],
        "fontSize": "14px",
        "fontWeight": 500,
        "lineHeight": 1.4
      },
      "$type": "typography"
    }
  },
  "spacing": {
    "xs": {
      "$value": "4px",
      "$type": "dimension"
    },
    "sm": {
      "$value": "8px",
      "$type": "dimension"
    },
    "md": {
      "$value": "16px",
      "$type": "dimension"
    },
    "lg": {
      "$value": "24px",
      "$type": "dimension"
    },
    "xl": {
      "$value": "32px",
      "$type": "dimension"
    }
  },
  "borderRadius": {
    "sm": {
      "$value": "4px",
      "$type": "dimension"
    },
    "md": {
      "$value": "8px",
      "$type": "dimension"
    },
    "lg": {
      "$value": "12px",
      "$type": "dimension"
    },
    "full": {
      "$value": "9999px",
      "$type": "dimension"
    }
  }
}