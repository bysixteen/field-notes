{
  "button": {
    "applies_to": {
      "sentiment": "all",
      "emphasis": "all",
      "size": "all",
      "state": "all"
    },
    "properties": {
      "backgroundColor": "{color.primary}",
      "textColor": "{color.on-primary}",
      "typography": "{typography.label-md}",
      "rounded": "{borderRadius.md}",
      "padding": "{spacing.8} {spacing.16}",
      "height": "40px"
    }
  },
  "card": {
    "applies_to": {
      "sentiment": ["neutral"],
      "emphasis": ["high"],
      "size": "all",
      "state": ["rest"]
    },
    "properties": {
      "backgroundColor": "{color.on-primary}",
      "rounded": "{borderRadius.md}",
      "padding": "{spacing.16}"
    }
  },
  "tooltip": {
    "applies_to": {
      "sentiment": ["neutral"],
      "emphasis": ["medium"],
      "size": ["sm", "md"],
      "state": ["rest", "hover"]
    },
    "properties": {
      "backgroundColor": "{color.primary}",
      "textColor": "{color.on-primary}",
      "rounded": "{borderRadius.md}"
    }
  }
}
