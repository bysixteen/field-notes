{
  "$schema": "https://schemas.designtokens.org/2025-10/schema.json",
  "color": {
    "primary": { "$type": "color", "$value": "#0066cc" },
    "on-primary": { "$type": "color", "$value": "#ffffff" },
    "neutral": { "$type": "color", "$value": "#222222" },
    "on-neutral": { "$type": "color", "$value": "#ffffff" },
    "positive": { "$type": "color", "$value": "#0a8a3a" },
    "warning": { "$type": "color", "$value": "#cc6600" },
    "danger": { "$type": "color", "$value": "#cc0033" }
  },
  "typography": {
    "label-md": {
      "$type": "typography",
      "$value": { "fontFamily": "Inter", "fontSize": "14px", "fontWeight": 500 }
    }
  },
  "spacing": {
    "8": { "$type": "dimension", "$value": "8px" },
    "16": { "$type": "dimension", "$value": "16px" }
  },
  "borderRadius": {
    "md": { "$type": "dimension", "$value": "6px" }
  }
}
