{
  "$schema": "https://schemas.designtokens.org/2025-10/schema.json",
  "color": {
    "primary": { "$type": "color", "$value": "{{primary_color}}" },
    "on-primary": { "$type": "color", "$value": "#ffffff" },
    "neutral": { "$type": "color", "$value": "#222222" },
    "on-neutral": { "$type": "color", "$value": "#ffffff" },
    "positive": { "$type": "color", "$value": "#0a8a3a" },
    "warning": { "$type": "color", "$value": "#cc6600" },
    "danger": { "$type": "color", "$value": "#cc0033" }
  },
  "typography": {
    "label-md": {
      "$type": "typography",
      "$value": { "fontFamily": "{{font_family}}", "fontSize": "14px", "fontWeight": 500 }
    }
  },
  "spacing": {
    "8": { "$type": "dimension", "$value": "8px" },
    "16": { "$type": "dimension", "$value": "16px" }
  },
  "borderRadius": {
    "md": { "$type": "dimension", "$value": "6px" }
  },
  "button": {
    "backgroundColor": { "$type": "color", "$value": "{color.primary}" },
    "textColor": { "$type": "color", "$value": "{color.on-primary}" },
    "typography": { "$type": "typography", "$value": "{typography.label-md}" },
    "rounded": { "$type": "dimension", "$value": "{borderRadius.md}" },
    "padding": { "$type": "dimension", "$value": "{spacing.8} {spacing.16}" }
  },
  "input": {
    "backgroundColor": { "$type": "color", "$value": "{color.on-primary}" },
    "textColor": { "$type": "color", "$value": "{color.neutral}" },
    "typography": { "$type": "typography", "$value": "{typography.label-md}" },
    "rounded": { "$type": "dimension", "$value": "{borderRadius.md}" },
    "padding": { "$type": "dimension", "$value": "{spacing.8} {spacing.16}" }
  },
  "badge": {
    "backgroundColor": { "$type": "color", "$value": "{color.primary}" },
    "textColor": { "$type": "color", "$value": "{color.on-primary}" },
    "typography": { "$type": "typography", "$value": "{typography.label-md}" },
    "rounded": { "$type": "dimension", "$value": "{borderRadius.md}" },
    "padding": { "$type": "dimension", "$value": "{spacing.8}" }
  },
  "alert": {
    "backgroundColor": { "$type": "color", "$value": "{color.primary}" },
    "textColor": { "$type": "color", "$value": "{color.on-primary}" },
    "typography": { "$type": "typography", "$value": "{typography.label-md}" },
    "rounded": { "$type": "dimension", "$value": "{borderRadius.md}" },
    "padding": { "$type": "dimension", "$value": "{spacing.16}" }
  },
  "card": {
    "backgroundColor": { "$type": "color", "$value": "{color.on-primary}" },
    "rounded": { "$type": "dimension", "$value": "{borderRadius.md}" },
    "padding": { "$type": "dimension", "$value": "{spacing.16}" }
  }
}
